<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YouTube Live Chat CSS Generator - CDB Final Edition</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Mitr&family=Outfit:wght@300;400;600;700&family=Inter:wght@400;700&family=Roboto+Mono&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#a32834',
                    }
                }
            }
        }
    </script>
    
    <style>
        :root {
            --nameTextColor: #ffebe9;
            --nameBackgroundColor: #a32834;
            --nameFontSize: 14px;
            --nameBorderRadius: 5px;
            --chatTextColor: #932331;
            --chatBackgroundColor: #ffffff;
            --chatFontSize: 18px;
            --chatBorderRadius: 10px;
            --chatOffset: 25px;
            --chatShadow: 2px 2px 10px 1px rgba(0, 0, 0, 0.2);
            --fontFamily: 'Mitr', sans-serif;
            --animDuration: 1s;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .chat-preview {
            background-color: #f1f5f9;
            padding: 30px;
            min-height: 300px;
        }

        .author-name {
            display: inline-block;
            font-family: var(--fontFamily);
            font-size: var(--nameFontSize);
            padding: 4px 8px;
            border-radius: var(--nameBorderRadius);
            background-color: var(--nameBackgroundColor);
            color: var(--nameTextColor);
            box-shadow: var(--chatShadow);
            animation: float_in var(--animDuration) ease;
        }

        .chat-message {
            display: inline-block;
            font-family: var(--fontFamily);
            font-size: var(--chatFontSize);
            line-height: 1.5;
            color: var(--chatTextColor);
            background-color: var(--chatBackgroundColor);
            padding: 8px 12px;
            border-radius: var(--chatBorderRadius);
            box-shadow: var(--chatShadow);
            margin-left: var(--chatOffset);
            margin-top: 2px;
            max-width: 85%;
        }

        .css-output {
            background-color: #1e293b;
            color: #f1f5f9;
            padding: 20px;
            border-radius: 8px;
            font-family: 'Roboto Mono', monospace;
            font-size: 13px;
            white-space: pre-wrap;
            border: 1px solid #334155;
        }

        @keyframes float_in {
            0% { transform: translateY(10px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px; height: 18px;
            background: #a32834;
            cursor: pointer;
            border-radius: 50%;
            border: 2px solid white;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">
    <div class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- Header Section -->
        <header class="mb-10 text-center">
            <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-2">
                YouTube Chat <span class="text-primary italic">Customizer</span>
            </h1>
            <p class="text-gray-500 text-sm">Versi Final Padat & Efektif</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
            <!-- PANEL KIRI: Konfigurasi -->
            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow-lg p-6 border border-gray-100">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                        <i class="fas fa-sliders-h mr-3 text-primary"></i> Pengaturan Chat
                    </h2>

                    <!-- Typography -->
                    <div class="mb-8">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Pilih Font</label>
                        <select id="fontFamily" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm outline-none focus:ring-2 focus:ring-primary/20 transition-all">
                            <option value="'Mitr', sans-serif">Mitr (Modern)</option>
                            <option value="'Outfit', sans-serif">Outfit (Clean)</option>
                            <option value="'Inter', sans-serif">Inter (Standard)</option>
                            <option value="'Roboto', sans-serif">Roboto</option>
                        </select>
                    </div>

                    <!-- Author Style -->
                    <div class="mb-8 p-4 bg-gray-50 rounded-xl border border-gray-200">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Warna & Gaya Nama</h3>
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Warna Teks</label>
                                <input type="color" id="nameTextColor" value="#ffebe9" class="w-full h-10 border-0 rounded cursor-pointer">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Latar Nama</label>
                                <input type="color" id="nameBackgroundColor" value="#a32834" class="w-full h-10 border-0 rounded cursor-pointer">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Ukuran Font (<span id="nameFontSizeValue">14px</span>)</label>
                                <input type="range" id="nameFontSize" min="10" max="40" value="14" class="w-full accent-primary">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Kebulatan (<span id="nameBorderRadiusValue">5px</span>)</label>
                                <input type="range" id="nameBorderRadius" min="0" max="40" value="5" class="w-full accent-primary">
                            </div>
                        </div>
                    </div>

                    <!-- Message Style -->
                    <div class="mb-8 p-4 bg-gray-50 rounded-xl border border-gray-200">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Gaya Pesan Chat</h3>
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Warna Teks</label>
                                <input type="color" id="chatTextColor" value="#932331" class="w-full h-10 border-0 rounded cursor-pointer">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Latar Pesan</label>
                                <input type="color" id="chatBackgroundColor" value="#ffffff" class="w-full h-10 border-0 rounded cursor-pointer">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Ukuran Font (<span id="chatFontSizeValue">18px</span>)</label>
                                <input type="range" id="chatFontSize" min="10" max="40" value="18" class="w-full accent-primary">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Kebulatan (<span id="chatBorderRadiusValue">10px</span>)</label>
                                <input type="range" id="chatBorderRadius" min="0" max="40" value="10" class="w-full accent-primary">
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Jarak Kiri (<span id="chatOffsetValue">25px</span>)</label>
                            <input type="range" id="chatOffset" min="0" max="60" value="25" class="w-full accent-primary">
                        </div>
                    </div>

                    <!-- Visual Mix -->
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Bayangan (<span id="shadowIntensityValue">20%</span>)</label>
                            <input type="range" id="shadowIntensity" min="0" max="100" value="20" class="w-full accent-primary">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Animasi (<span id="animDurationValue">1.0s</span>)</label>
                            <input type="range" id="animDuration" min="0" max="2" step="0.1" value="1" class="w-full accent-primary">
                        </div>
                    </div>

                    <button id="resetBtn" class="w-full py-3 bg-gray-100 text-gray-600 rounded-lg text-sm font-bold hover:bg-gray-200 transition-colors">
                        <i class="fas fa-undo mr-2"></i> KEMBALIKAN KE DEFAULT
                    </button>
                </div>
            </div>
            
            <!-- PANEL KANAN: Preview & Output (Sticky) -->
            <div class="space-y-6 md:sticky md:top-6">
                <!-- Preview Section -->
                <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-gray-100">
                    <div class="bg-gray-800 py-3 px-5 flex justify-between items-center text-white">
                        <span class="font-bold text-sm"><i class="fas fa-eye mr-2 text-primary"></i> Preview Live Chat</span>
                        <button id="bgToggle" class="w-8 h-8 rounded-full bg-gray-700 hover:bg-gray-600 flex items-center justify-center">
                            <i class="fas fa-moon text-xs"></i>
                        </button>
                    </div>
                    
                    <div id="previewArea" class="chat-preview">
                        <div class="mb-4">
                            <div class="author-name">CDB Official</div>
                            <br>
                            <div class="chat-message">Preview ini sekarang berada di sisi kanan halaman!</div>
                        </div>
                        <div class="mb-4">
                            <div class="author-name" style="background-color: #2ecc71;">User Baru</div>
                            <br>
                            <div class="chat-message">Tata letak menjadi lebih efektif dan tidak memanjang.</div>
                        </div>
                    </div>
                </div>

                <!-- Output Section -->
                <div class="bg-white rounded-xl shadow-lg p-5 border border-gray-100">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="font-bold text-gray-800">Hasil Kode CSS (Salin ke OBS)</h3>
                        <button id="copyBtn" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-xs font-bold hover:bg-blue-700 transition-all flex items-center">
                            <i class="fas fa-copy mr-2"></i> SALIN CSS
                        </button>
                    </div>
                    <div id="cssOutput" class="css-output"></div>
                </div>
            </div>
        </div>
        
        <footer class="mt-20 text-center text-gray-400 text-[10px] uppercase tracking-[3px]">
            Final Update &copy; 2024 Audition Podcast
        </footer>
    </div>

    <script>
        // DOM Elements
        const ids = ['nameTextColor', 'nameBackgroundColor', 'nameFontSize', 'nameBorderRadius', 
                     'chatTextColor', 'chatBackgroundColor', 'chatFontSize', 'chatBorderRadius', 
                     'chatOffset', 'fontFamily', 'shadowIntensity', 'animDuration'];
        const elements = {};
        ids.forEach(id => elements[id] = document.getElementById(id));

        const previewArea = document.getElementById('previewArea');
        const cssOutput = document.getElementById('cssOutput');
        const copyBtn = document.getElementById('copyBtn');

        function update() {
            // Update Preview variables
            const root = document.documentElement;
            const shadowVal = elements.shadowIntensity.value / 100;
            
            root.style.setProperty('--nameTextColor', elements.nameTextColor.value);
            root.style.setProperty('--nameBackgroundColor', elements.nameBackgroundColor.value);
            root.style.setProperty('--nameFontSize', elements.nameFontSize.value + 'px');
            root.style.setProperty('--nameBorderRadius', elements.nameBorderRadius.value + 'px');
            
            root.style.setProperty('--chatTextColor', elements.chatTextColor.value);
            root.style.setProperty('--chatBackgroundColor', elements.chatBackgroundColor.value);
            root.style.setProperty('--chatFontSize', elements.chatFontSize.value + 'px');
            root.style.setProperty('--chatBorderRadius', elements.chatBorderRadius.value + 'px');
            root.style.setProperty('--chatOffset', elements.chatOffset.value + 'px');
            root.style.setProperty('--chatShadow', `2px 2px 10px 1px rgba(0,0,0,${shadowVal})`);
            root.style.setProperty('--fontFamily', elements.fontFamily.value);
            root.style.setProperty('--animDuration', elements.animDuration.value + 's');

            // Update Labels
            document.getElementById('nameFontSizeValue').textContent = elements.nameFontSize.value + 'px';
            document.getElementById('nameBorderRadiusValue').textContent = elements.nameBorderRadius.value + 'px';
            document.getElementById('chatFontSizeValue').textContent = elements.chatFontSize.value + 'px';
            document.getElementById('chatBorderRadiusValue').textContent = elements.chatBorderRadius.value + 'px';
            document.getElementById('chatOffsetValue').textContent = elements.chatOffset.value + 'px';
            document.getElementById('shadowIntensityValue').textContent = elements.shadowIntensity.value + '%';
            document.getElementById('animDurationValue').textContent = elements.animDuration.value + 's';

            generateCSS();
        }

        function generateCSS() {
            const css = `/* YouTube Live Chat Custom CSS by CDB */
@import url('https://fonts.googleapis.com/css2?family=Mitr&display=swap');

:root {
    --nameTextColor: ${elements.nameTextColor.value};
    --nameBackgroundColor: ${elements.nameBackgroundColor.value};
    --nameFontSize: ${elements.nameFontSize.value}px;
    --nameBorderRadius: ${elements.nameBorderRadius.value}px;
    --chatTextColor: ${elements.chatTextColor.value};
    --chatBackgroundColor: ${elements.chatBackgroundColor.value};
    --chatFontSize: ${elements.chatFontSize.value}px;
    --chatBorderRadius: ${elements.chatBorderRadius.value}px;
    --chatOffset: ${elements.chatOffset.value}px;
    --chatShadow: 2px 2px 10px 1px rgba(0,0,0,${elements.shadowIntensity.value / 100});
    --fontFamily: ${elements.fontFamily.value};
    --animDuration: ${elements.animDuration.value}s;
}

body { overflow: hidden !important; background: transparent !important; }
yt-live-chat-renderer { background: transparent !important; }
yt-live-chat-text-message-renderer { background: transparent !important; }

/* Menghilangkan UI yang tidak perlu */
yt-live-chat-header-renderer, yt-live-chat-message-input-renderer, #ticker { display: none !important; }

yt-live-chat-text-message-renderer #author-name {
    display: inline-block !important;
    font-family: var(--fontFamily) !important;
    font-size: var(--nameFontSize) !important;
    padding: 4px 8px !important;
    border-radius: var(--nameBorderRadius) !important;
    background-color: var(--nameBackgroundColor) !important;
    color: var(--nameTextColor) !important;
    box-shadow: var(--chatShadow) !important;
    animation: float_in var(--animDuration) ease;
    margin-bottom: 2px !important;
}

yt-live-chat-text-message-renderer #message {
    display: inline-block !important;
    font-family: var(--fontFamily) !important;
    border-radius: var(--chatBorderRadius) !important;
    font-size: var(--chatFontSize) !important;
    line-height: 1.5 !important;
    color: var(--chatTextColor) !important;
    padding: 8px 12px !important;
    background-color: var(--chatBackgroundColor) !important;
    margin-left: var(--chatOffset) !important;
    box-shadow: var(--chatShadow) !important;
}

@keyframes float_in { 0% { opacity: 0; transform: translateY(10px); } 100% { opacity: 1; transform: translateY(0); } }`;
            cssOutput.textContent = css;
        }

        // Listeners
        ids.forEach(id => elements[id].addEventListener('input', update));
        
        document.getElementById('bgToggle').addEventListener('click', () => {
            previewArea.classList.toggle('bg-gray-900');
            previewArea.classList.toggle('bg-gray-50');
        });

        document.getElementById('resetBtn').addEventListener('click', () => {
            location.reload();
        });

        copyBtn.addEventListener('click', () => {
            navigator.clipboard.writeText(cssOutput.textContent);
            copyBtn.innerHTML = '<i class="fas fa-check mr-2"></i> DISALIN!';
            setTimeout(() => copyBtn.innerHTML = '<i class="fas fa-copy mr-2"></i> SALIN CSS', 2000);
        });

        // Initialize
        update();
    </script>
</body>
</html>
